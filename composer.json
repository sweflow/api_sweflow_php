{
    "require": {
        "ext-pdo_pgsql": "*",
        "firebase/php-jwt": "^7.0",
        "vlucas/phpdotenv": "^5.6",
        "ramsey/uuid": "^4.9",
        "phpmailer/phpmailer": "^6.9",
        "composer/semver": "^3.4"
    },
    "autoload": {
        "psr-4": {
            "Src\\": "src/",
            "SweflowModules\\Email\\": "src/Modules/Email/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "phpstan/phpstan": "^2.1"
    }
}
