{
    "require": {
        "ext-pdo_pgsql": "*",
        "firebase/php-jwt": "^7.0",
        "vlucas/phpdotenv": "^5.6",
        "ramsey/uuid": "^4.9",
        "phpmailer/phpmailer": "^6.9",
        "sweflow/module-email": "*"
    },
    "autoload": {
        "psr-4": {
            "Src\\": "src/",
            "Src\\Modules\\": "src/Modules/",
            "SweflowModules\\Email\\": "src/Modules/Email/src/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "plugins/sweflow-module-*",
            "options": {
                "symlink": true
            }
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}