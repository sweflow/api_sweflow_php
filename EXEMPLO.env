#--------------------------
# Configuração da aplicação
#--------------------------
APP_NAME="Sweflow API"
APP_DESCRICAO="Esquema de API para o projetos"
APP_LOGO_URL="/favicon.ico"
APP_VERSION=1.0.0
APP_ENV=production
APP_DEBUG=false
APP_PORT=3005
APP_HOST=127.0.0.1
APP_URL=https://api.vupi.us
API_BASE_URL=https://api.vupi.us
APP_URL_FRONTEND=
# Domínio sem protocolo — usado pelo Caddyfile
APP_DOMAIN=api.vupi.us
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://localhost:3000,http://localhost:5173,http://127.0.0.1:5501,http://localhost:5501,https://api.vupi.us
#--------------------------

# Configuração do fuso horário
APP_TIMEZONE=America/Bahia
#--------------------------

# Cookies (auth)
# HTTPS + mesmo domínio: Lax + Secure=true
# HTTPS + domínios diferentes (frontend separado): None + Secure=true
COOKIE_SAMESITE=Lax
COOKIE_SECURE=true
COOKIE_HTTPONLY=true
COOKIE_DOMAIN=
#--------------------------

# Configuração do banco de dados (conexão principal — core + módulos nativos)
DB_CONEXAO=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NOME=sweflow_db
DB_USUARIO=admin
DB_SENHA=
# ⚠ OBRIGATÓRIO em produção: mínimo 16 caracteres para banco remoto
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_PREFIX=
#--------------------------

# Migrations
# Timeout do lock de execução em segundos (padrão: 10)
MIGRATE_LOCK_TIMEOUT=10
#--------------------------

# Segunda conexão de banco (módulos externos)
# Pode ser um driver diferente: ex. core em PostgreSQL e módulos em MySQL.
DB2_CONEXAO=
DB2_HOST=
DB2_PORT=
DB2_NOME=
DB2_USUARIO=
DB2_SENHA=
DB2_CHARSET=utf8mb4
DB2_COLLATION=utf8mb4_unicode_ci
DB2_PREFIX=
#--------------------------

# Configuração do JWT
JWT_SECRET=
JWT_API_SECRET=
JWT_ISSUER=https://api.vupi.us
JWT_AUDIENCE=https://api.vupi.us
JWT_EXPIRATION_TIME=900
REFRESH_TOKEN_EXPIRATION_SECONDS=2592000
REFRESH_MAX_PER_USER=5
REVOCATION_STORAGE=database

# JWT Key Rotation — permite rotação sem derrubar usuários ativos
# JWT_SECRET_KID identifica o secret atual (ex: v2)
# JWT_SECRET_v1 mantém o secret anterior para aceitar tokens antigos
# JWT_SECRET_v2 é o novo secret (aponte JWT_SECRET para ele também)
JWT_SECRET_KID=
JWT_SECRET_v1=
JWT_SECRET_v2=
#--------------------------

# Redis (opcional — habilita rate limiting distribuído para múltiplos containers)
# Se não configurado, usa storage em arquivo (servidor único)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=sweflow:
#--------------------------

# Configuração do Mailer
MAILER_DEBUG=false
MAILER_HOST=smtp.gmail.com
MAILER_PORT=587
MAILER_USERNAME=sweflowapi@gmail.com
MAILER_PASSWORD=
MAILER_ENCRYPTION=tls
MAILER_FROM_EMAIL=no-reply@example.com
MAILER_FROM_NAME="Sweflow API"
MAILER_REPLY_TO=

API_KEY=

# Configuração do Cache
CACHE_DRIVER=file
CACHE_PATH=./cache
#--------------------------

# Proxy reverso (Caddy/Nginx/Cloudflare)
# true  → confia em X-Forwarded-Proto do proxy (Caddy em produção)
# false → sem proxy, php -S direto (desenvolvimento sem Caddy)
TRUST_PROXY=true
# Email para notificações do Let's Encrypt (usado pelo Caddyfile)
CADDY_EMAIL=admin@vupi.us
#--------------------------

# ── Docker Compose ───────────────────────────────────────
# Portas expostas pelos containers (mude se já estiverem em uso)
POSTGRES_PORT=5432
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=
ADMINER_PORT=8080
# Nota: DB_NOME, DB_USUARIO, DB_SENHA e APP_TIMEZONE também são
# lidos pelo docker-compose — defina-os nas seções acima.
# Com Docker + port forwarding, DB_HOST=localhost funciona normalmente.
#--------------------------

# Admin padrão criado pelo seeder
# ⚠ TROQUE EM PRODUÇÃO
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=
ADMIN_NAME=Administrador
ADMIN_USERNAME=admin
#--------------------------
