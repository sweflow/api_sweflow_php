#--------------------------
# Configuração da aplicação
#--------------------------
APP_NAME="Sweflow API"
APP_DESCRICAO="Esquema de API para o projetos"
APP_LOGO_URL="/favicon.ico"
APP_VERSION=1.0.0
APP_ENV=production
APP_DEBUG=false
APP_PORT=3005
APP_URL=https://api.typper.shop
API_BASE_URL=https://api.typper.shop
APP_URL_FRONTEND=
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://localhost:3000,http://localhost:5173,http://127.0.0.1:5501,http://localhost:5501,https://api.typper.shop
#--------------------------

# Configuração do fuso horário
APP_TIMEZONE=America/Bahia
#--------------------------

# Cookies (auth)
# HTTPS + mesmo domínio: Lax + Secure=true
# HTTPS + domínios diferentes (frontend separado): None + Secure=true
COOKIE_SAMESITE=Lax
COOKIE_SECURE=true
COOKIE_HTTPONLY=true
COOKIE_DOMAIN=
#--------------------------

# Configuração do banco de dados
DB_CONEXAO=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NOME=sweflow_db
DB_USUARIO=admin
DB_SENHA=123456
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_PREFIX=
#--------------------------

# Configuração do JWT
JWT_SECRET=
JWT_API_SECRET=
JWT_ISSUER=https://api.typper.shop
JWT_AUDIENCE=https://api.typper.shop
JWT_EXPIRATION_TIME=3600
REFRESH_TOKEN_EXPIRATION_SECONDS=2592000
REFRESH_MAX_PER_USER=5
REVOCATION_STORAGE=database
#--------------------------

# Configuração do Mailer
MAILER_DEBUG=false
MAILER_HOST=smtp.gmail.com
MAILER_PORT=587
MAILER_USERNAME=sweflowapi@gmail.com
MAILER_PASSWORD=
MAILER_ENCRYPTION=tls
MAILER_FROM_EMAIL=no-reply@example.com
MAILER_FROM_NAME="Sweflow API"
MAILER_REPLY_TO=

API_KEY=

# Configuração do Cache
CACHE_DRIVER=file
CACHE_PATH=./cache
#--------------------------

# Proxy reverso (Caddy/Nginx/Cloudflare)
# true  → confia em X-Forwarded-Proto do proxy (Caddy em produção)
# false → sem proxy, php -S direto (desenvolvimento sem Caddy)
TRUST_PROXY=false
#--------------------------
