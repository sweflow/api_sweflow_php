#--------------------------
# Configuração da aplicação
#--------------------------
APP_NAME="Sweflow API"
APP_DESCRICAO="Esquema de API para o projetos"
APP_LOGO_URL="https://localhost:3005/public/favicon.ico"
APP_VERSION=1.0.0
APP_ENV=development
APP_DEBUG=true
APP_PORT=3005
APP_URL=http://localhost:3005
APP_URL_FRONTEND=
# Cookies (auth)
# Em desenvolvimento local (HTTP): Lax + Secure=false
# Em produção (HTTPS, domínios diferentes): None + Secure=true
COOKIE_SAMESITE=Lax
COOKIE_SECURE=false
COOKIE_DOMAIN=
#--------------------------

# Configuração do fuso horário
APP_TIMEZONE=America/Bahia
#--------------------------


# Configuração do banco de dados
DB_CONEXAO=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NOME=sweflow_db
DB_USUARIO=admin
DB_SENHA=123456
DB_PREFIX=
#--------------------------


# Configuração do JWT
JWT_SECRET=
JWT_API_SECRET=
JWT_ISSUER=http://localhost:3005
JWT_AUDIENCE=http://localhost:3005
JWT_EXPIRATION_TIME=3600
REFRESH_TOKEN_EXPIRATION_SECONDS=2592000
REVOCATION_STORAGE=database
#--------------------------

# Configuração do Mailer
MAILER_DEBUG=true
MAILER_HOST=smtp.gmail.com
MAILER_PORT=587
MAILER_USERNAME=
MAILER_PASSWORD=
MAILER_ENCRYPTION=tls
MAILER_FROM_EMAIL=no-reply@example.com
MAILER_FROM_NAME="Sweflow API"
MAILER_REPLY_TO=
MAILER_LOGO_URL=

# Configuração do Cache
CACHE_DRIVER=file
CACHE_PATH=./cache
#--------------------------

# Admin padrão (criado pelo seeder: php sweflow migrate --seed)
# ⚠ TROQUE EM PRODUÇÃO
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrador
ADMIN_USERNAME=admin

