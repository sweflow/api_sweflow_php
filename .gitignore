# ── Storage (runtime — manter .gitkeep, ignorar conteúdo) ─────────────────
/storage/ratelimit/*
!/storage/ratelimit/.gitkeep
/storage/threat/*
!/storage/threat/.gitkeep
/storage/circuit/*
!/storage/circuit/.gitkeep
/storage/backups/*
!/storage/backups/.gitkeep
/storage/ide_projects/*/
/storage/server.log
