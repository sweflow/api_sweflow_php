# Ignore diretórios:
/vendor/
/storage/ratelimit/
/storage/modules_cache.php
/storage/backups/

# Ignore arquivos:
.env
.env.local
.env.production
.env.docker

# Docker — dados locais (não commitar)
.env.docker.local
docker/postgres/data/
docker/mysql/data/

# Caddy — certificados locais gerados pelo mkcert
*.pem
*.key

# Tokens e credenciais geradas localmente
_token.txt
_token_clean.txt
*.token.txt
gerar_jwt.php

# Scripts de debug locais
_debug_*.php
_debug_*.txt
