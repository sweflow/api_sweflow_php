# ── Dependências ──────────────────────────────────────────────────────────
/vendor/

# ── Ambiente ──────────────────────────────────────────────────────────────
.env
.env.local
.env.production
.env.docker
.env.docker.local

# ── Storage (runtime — manter .gitkeep, ignorar conteúdo) ─────────────────
/storage/ratelimit/*
!/storage/ratelimit/.gitkeep
/storage/threat/*
!/storage/threat/.gitkeep
/storage/circuit/*
!/storage/circuit/.gitkeep
/storage/backups/*
!/storage/backups/.gitkeep
/storage/ide_projects/*/
/storage/server.log
/storage/server.pid
/storage/modules_cache.php
/storage/security_results.txt

# ── Cache ─────────────────────────────────────────────────────────────────
/cache/*
!/cache/.gitkeep

# ── Testes ────────────────────────────────────────────────────────────────
.phpunit.result.cache
.phpunit.cache/

# ── Docker ────────────────────────────────────────────────────────────────
docker/postgres/data/
docker/mysql/data/

# ── Certificados ──────────────────────────────────────────────────────────
*.pem
*.key

# ── Backups de banco ──────────────────────────────────────────────────────
*.sql
*.sql.gz

# ── Arquivos de debug (nunca commitar) ────────────────────────────────────
_debug_*.php
_debug_*.txt
_test_*.php
_check_*.php
diagnostico.php
gerar_jwt.php
fix_producao.sh
_token.txt
_token_clean.txt
*.token.txt

# ── IDE/Editor ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
