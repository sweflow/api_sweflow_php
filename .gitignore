/storage/security_results.txt
/storage/modules_state.json
/storage/plugins_registry.json
/storage/marketplace_stats.json
/storage/capabilities_registry.json

# ── src/storage (runtime interno — mesmo padrão) ──────────────────────────
/src/storage/ratelimit/*
!/src/storage/ratelimit/.gitkeep
/src/storage/modules_state.json

