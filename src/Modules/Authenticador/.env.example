# ═══════════════════════════════════════════════════════════
# Módulo Authenticador - Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════

# ── JWT (JSON Web Tokens) ──────────────────────────────────
# Chave secreta para assinar tokens JWT (mínimo 32 caracteres)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# Algoritmo de assinatura JWT (HS256, HS384, HS512, RS256, etc)
JWT_ALGORITHM=HS256

# Tempo de expiração do access token (em segundos)
# Padrão: 3600 (1 hora)
JWT_ACCESS_TOKEN_TTL=3600

# Tempo de expiração do refresh token (em segundos)
# Padrão: 2592000 (30 dias)
JWT_REFRESH_TOKEN_TTL=2592000

# ── OAuth2 - Google ────────────────────────────────────────
# Habilitar login com Google
GOOGLE_OAUTH_ENABLED=true

# Client ID do Google OAuth2
# Obtenha em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Client Secret do Google OAuth2
GOOGLE_CLIENT_SECRET=your-google-client-secret

# URL de redirecionamento após login (deve estar registrada no Google Console)
GOOGLE_REDIRECT_URI=http://localhost:3005/api/auth/google/callback

# Escopos solicitados ao Google
# Padrão: openid email profile
GOOGLE_SCOPES=openid,email,profile

# ── OAuth2 - Facebook (futuro) ─────────────────────────────
FACEBOOK_OAUTH_ENABLED=false
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=

# ── OAuth2 - GitHub (futuro) ───────────────────────────────
GITHUB_OAUTH_ENABLED=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=

# ── Rate Limiting ──────────────────────────────────────────
# Número máximo de requisições por janela de tempo
RATE_LIMIT_PUBLIC=100
RATE_LIMIT_AUTHENTICATED=200
RATE_LIMIT_ADMIN=500
RATE_LIMIT_LOGIN=5

# Janela de tempo para rate limit (em segundos)
RATE_LIMIT_WINDOW=60

# ── Sessões ────────────────────────────────────────────────
# Tempo de expiração de sessões (em dias)
SESSION_LIFETIME=7

# Número máximo de sessões ativas por usuário
MAX_SESSIONS_PER_USER=5

# ── 2FA (Two-Factor Authentication) ────────────────────────
# Habilitar 2FA
TWO_FACTOR_ENABLED=true

# Nome do aplicativo para TOTP (aparece no Google Authenticator)
TWO_FACTOR_ISSUER=Vupi.us

# Número de códigos de backup gerados
TWO_FACTOR_BACKUP_CODES=10

# ── Segurança ──────────────────────────────────────────────
# Número máximo de tentativas de login antes de bloquear
MAX_LOGIN_ATTEMPTS=5

# Tempo de bloqueio após tentativas excessivas (em minutos)
LOGIN_LOCKOUT_TIME=30

# Tempo de vida dos tokens de recuperação de senha (em horas)
PASSWORD_RESET_TOKEN_TTL=24

# Tempo de vida dos tokens de verificação de email (em horas)
EMAIL_VERIFICATION_TOKEN_TTL=24

# ── CORS ───────────────────────────────────────────────────
# Origens permitidas (separadas por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3005

# Permitir credenciais (cookies) em requisições CORS
CORS_ALLOW_CREDENTIALS=true

# ── Logs e Auditoria ───────────────────────────────────────
# Habilitar log de tentativas de login
LOG_LOGIN_ATTEMPTS=true

# Habilitar log de ações de segurança
LOG_SECURITY_EVENTS=true

# Tempo de retenção de logs (em dias)
LOG_RETENTION_DAYS=90

# ── Limpeza Automática ─────────────────────────────────────
# Habilitar limpeza automática de tokens expirados
AUTO_CLEANUP_ENABLED=true

# Intervalo de limpeza (em horas)
AUTO_CLEANUP_INTERVAL=24

# ── Desenvolvimento ────────────────────────────────────────
# Modo debug (NUNCA use true em produção!)
AUTH_DEBUG=false

# Ambiente (local, staging, production)
AUTH_ENV=local
